            "height": "0"
          }
        },
        "caret-blink": {
          "0%,70%,100%": {
            "opacity": "1"
          },
          "20%,50%": {
            "opacity": "0"
          }
        }
      },
      "animation": {
        "accordion-down": "accordion-down var(--motion-duration-smooth) var(--motion-easing-smooth)",
        "accordion-up": "accordion-up var(--motion-duration-smooth) var(--motion-easing-smooth)",
        "caret-blink": "caret-blink 1.25s ease-out infinite"
      }
    }
  }
}
